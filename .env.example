# Google Gemini AI Configuration
GEMINI_API_KEY=your_google_generativeai_api_key_here
GEMINI_MODEL_NAME=gemini-pro
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.9
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_MIN_CONFIDENCE=0.6
GEMINI_HIGH_CONFIDENCE_THRESHOLD=0.8
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=2

# GitHub Copilot SDK Configuration
# GitHub personal access token with models:read scope
# (or a Copilot API token)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# Model to use through GitHub Models / Copilot API
# Options: gpt-4o, gpt-4o-mini, claude-3.5-sonnet, meta-llama-3.1-405b-instruct
COPILOT_MODEL=gpt-4o

# Optional Copilot agent tuning
COPILOT_TOOL_TIMEOUT=30   # seconds per tool call
COPILOT_API_TIMEOUT=60    # seconds per LLM API call
COPILOT_MAX_ITERATIONS=10 # max agentic loop iterations

# Flask Configuration
DEBUG=False
FLASK_PORT=5005
