# ── Runtime environment ────────────────────────────────────────────────────────
# Controls which LLM backend is used:
#   dev        → local Ollama  (default, optimised for Apple Silicon M1/M2)
#   production → cloud LLM provider (see LLM_PROVIDER / LLM_API_KEY below)
APP_ENV=dev

# Alpha Vantage Stock Data API
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ── Dev / Local LLM (Ollama) ──────────────────────────────────────────────────
# Used when APP_ENV=dev
# When running inside Docker, use host.docker.internal to reach Ollama on the host
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=phi3:mini

# ── Production / Cloud LLM ────────────────────────────────────────────────────
# Used when APP_ENV=production
# LLM_PROVIDER: anthropic | openai | gemini
LLM_PROVIDER=gemini
# Single API key for whichever provider is selected above
LLM_API_KEY=your_cloud_llm_api_key_here

# Optional per-provider model overrides
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL_NAME=gemini-2.0-flash

# ── Google Gemini AI (legacy / direct usage) ──────────────────────────────────
# These are still read by app/config/gemini_config.py when Gemini is used
# as the cloud provider via LLM_PROVIDER=gemini
GEMINI_API_KEY=your_google_generativeai_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.9
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_MIN_CONFIDENCE=0.6
GEMINI_HIGH_CONFIDENCE_THRESHOLD=0.8
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=2

# ── Flask Configuration ───────────────────────────────────────────────────────
DEBUG=False
FLASK_PORT=5005

